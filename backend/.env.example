# Environment Variables Template
# Copy this file to .env and fill in your values

# Database
ConnectionStrings__DefaultConnection=Server=localhost;Database=AdPhotoManager;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True

# JWT Configuration
Jwt__SecretKey=your-secret-key-minimum-32-characters-long-for-production
Jwt__Issuer=AdPhotoManager
Jwt__Audience=AdPhotoManager
Jwt__ExpirationMinutes=60

# Active Directory
ActiveDirectory__Server=your-ad-server.com
ActiveDirectory__Port=389
ActiveDirectory__UseSsl=false
ActiveDirectory__ServiceAccount=CN=Service Account,OU=Users,DC=domain,DC=com
ActiveDirectory__ServicePassword=YourServicePassword
ActiveDirectory__BaseDn=DC=domain,DC=com
ActiveDirectory__AllowedOrganizations__0=IT Department
ActiveDirectory__AllowedOrganizations__1=HR Department

# Logging
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# CORS
AllowedOrigins__0=http://localhost:5173
AllowedOrigins__1=http://localhost:3000
